# MongoDB (Atlas)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=Cluster0

# JWT
JWT_SECRET=change_this_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# App
NODE_ENV=production
PORT=3109

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,https://greendg.craftassist.cloud

# Frontend URL (change for production)
FRONTEND_URL=https://greendg.craftassist.cloud/book
